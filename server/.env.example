# Martin Audit System — Backend Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to git

PORT=3001

# Infor CloudSuite OAuth2
INFOR_TENANT_ID=your_tenant_id_here
INFOR_SSO_BASE=https://mingle-sso.inforcloudsuite.com
INFOR_ION_BASE=https://mingle-ionapi.inforcloudsuite.com
INFOR_CLIENT_ID=your_client_id_here
INFOR_CLIENT_SECRET=your_client_secret_here

# Service Account Credentials (same as your Power Automate flow)
# Username: the full service account ID from your Power Automate grant_type=password body
# Password: the password value from that same body
# Both values may contain special characters — wrap in double quotes
INFOR_USERNAME="your_service_account_username_here"
INFOR_PASSWORD="your_service_account_password_here"

# SXe API login
INFOR_CONO=1
INFOR_OPER=CP01

# CORS — allowed frontend origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000
